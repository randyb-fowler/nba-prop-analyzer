# Copy to .env for local dev, or set these in Render's Environment tab.
# Never commit real secrets — .env is gitignored.

# Session signing key (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Public base URL of the app (no trailing slash).
# Local: http://localhost:8000  |  Prod: https://nba-prop-analyzer-w19a.onrender.com
APP_BASE_URL=http://localhost:8000

# Database. Leave unset locally to use SQLite (./dev.db).
# Production: Neon Postgres connection string.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID, "Web application")
# Authorized redirect URIs must include {APP_BASE_URL}/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (test mode). Dashboard → Developers → API keys / Webhooks.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Live odds (the-odds-api.com). Free tier. Without it, the Live Line card
# just doesn't appear — everything else works.
ODDS_API_KEY=
